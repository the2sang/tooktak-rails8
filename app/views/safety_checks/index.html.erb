<%= page_header("안전점검") { btn_primary("+ 새 점검", new_safety_check_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">점검일</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">점검자</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">종합결과</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">비고</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @safety_checks.each do |sc| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm"><%= link_to format_date(sc.check_date), sc, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= sc.project.name.truncate(25) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= sc.checker&.name %></td>
          <td class="px-5 py-3 text-sm">
            <% color = sc.overall_result == "양호" ? :green : sc.overall_result == "주의" ? :yellow : :red %>
            <%= badge(sc.overall_result || "-", color) %>
          </td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= sc.notes&.truncate(40) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
