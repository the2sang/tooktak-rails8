<%= page_header("작업지시서") { btn_primary("+ 새 작업지시", new_work_order_path) } %>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">지시번호</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">위치</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">담당자</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">우선순위</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @work_orders.each do |wo| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-500"><%= wo.order_no %></td>
          <td class="px-5 py-3 text-sm"><%= link_to wo.title.truncate(30), wo, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= link_to wo.project.name.truncate(20), wo.project, class: "hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= wo.location %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= wo.assigned_to&.name %></td>
          <td class="px-5 py-3 text-sm"><%= priority_badge(wo.priority) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(wo.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
