<%= page_header("프로젝트") { btn_primary("+ 새 프로젝트", new_project_path) } %>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">공사번호</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">공사명</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">시공사</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">현장소장</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">공정률</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @projects.each do |project| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-4 text-sm text-gray-500"><%= project.project_no %></td>
          <td class="px-5 py-4 text-sm">
            <%= link_to project.name, project, class: "font-medium text-gray-900 hover:text-blue-600" %>
            <p class="text-xs text-gray-400"><%= project.project_type_i18n %></p>
          </td>
          <td class="px-5 py-4 text-sm text-gray-500"><%= project.contractor&.name %></td>
          <td class="px-5 py-4 text-sm text-gray-500"><%= project.manager&.name %></td>
          <td class="px-5 py-4 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-16 bg-gray-200 rounded-full h-2">
                <div class="bg-blue-600 h-2 rounded-full" style="width: <%= project.progress_rate %>%"></div>
              </div>
              <span class="text-gray-700"><%= project.progress_rate %>%</span>
            </div>
          </td>
          <td class="px-5 py-4 text-sm"><%= status_badge(project.status) %></td>
          <td class="px-5 py-4 text-sm text-right">
            <%= link_to "편집", edit_project_path(project), class: "text-blue-600 hover:text-blue-800" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
