<%= page_header(@project.name) do %>
  <div class="flex gap-2">
    <%= btn_secondary("편집", edit_project_path(@project)) %>
    <%= btn_primary("+ 작업지시", new_project_work_order_path(@project)) %>
  </div>
<% end %>

<!-- 프로젝트 정보 -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <div class="lg:col-span-2 bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-semibold mb-4">프로젝트 정보</h3>
    <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div><dt class="text-gray-500">공사번호</dt><dd class="font-medium"><%= @project.project_no %></dd></div>
      <div><dt class="text-gray-500">공사유형</dt><dd><%= @project.project_type_i18n %></dd></div>
      <div><dt class="text-gray-500">발주처</dt><dd><%= @project.client_company&.name || "-" %></dd></div>
      <div><dt class="text-gray-500">시공사</dt><dd><%= @project.contractor&.name || "-" %></dd></div>
      <div><dt class="text-gray-500">현장소장</dt><dd><%= @project.manager&.name || "-" %></dd></div>
      <div><dt class="text-gray-500">상태</dt><dd><%= status_badge(@project.status) %></dd></div>
      <div><dt class="text-gray-500">착공일</dt><dd><%= format_date(@project.start_date) %></dd></div>
      <div><dt class="text-gray-500">준공예정일</dt><dd><%= format_date(@project.planned_end_date) %></dd></div>
      <div><dt class="text-gray-500">계약금액</dt><dd><%= format_amount(@project.contract_amount) %></dd></div>
      <div><dt class="text-gray-500">예산금액</dt><dd><%= format_amount(@project.budget_amount) %></dd></div>
      <div class="col-span-2"><dt class="text-gray-500">주소</dt><dd><%= @project.address || "-" %></dd></div>
    </dl>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h3 class="text-lg font-semibold mb-4">공정률</h3>
    <div class="flex items-center justify-center">
      <div class="relative w-32 h-32">
        <svg class="w-32 h-32 transform -rotate-90" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="50" fill="none" stroke="#e5e7eb" stroke-width="10"/>
          <circle cx="60" cy="60" r="50" fill="none" stroke="#2563eb" stroke-width="10"
                  stroke-dasharray="<%= 314.16 %>" stroke-dashoffset="<%= 314.16 * (1 - (@project.progress_rate || 0) / 100.0) %>"
                  stroke-linecap="round"/>
        </svg>
        <span class="absolute inset-0 flex items-center justify-center text-2xl font-bold text-gray-900">
          <%= @project.progress_rate %>%
        </span>
      </div>
    </div>

    <h3 class="text-lg font-semibold mt-6 mb-3">참여자</h3>
    <ul class="space-y-2">
      <% @members.each do |pm| %>
        <li class="flex items-center gap-2 text-sm">
          <span class="flex h-7 w-7 items-center justify-center rounded-full bg-gray-200 text-xs font-medium"><%= pm.user.name.first %></span>
          <span class="text-gray-900"><%= pm.user.name %></span>
          <span class="text-gray-400 text-xs"><%= pm.role_i18n %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>

<!-- 작업지시서 -->
<div class="bg-white shadow rounded-lg mb-6">
  <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
    <h3 class="text-lg font-semibold">작업지시서</h3>
    <%= link_to "전체보기", work_orders_path(project_id: @project.id), class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">지시번호</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">담당자</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">우선순위</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @work_orders.each do |wo| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-500"><%= wo.order_no %></td>
          <td class="px-5 py-3 text-sm"><%= link_to wo.title, wo, class: "text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= wo.assigned_to&.name %></td>
          <td class="px-5 py-3 text-sm"><%= priority_badge(wo.priority) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(wo.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- 이슈 -->
<div class="bg-white shadow rounded-lg">
  <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
    <h3 class="text-lg font-semibold">이슈/하자</h3>
    <%= link_to "전체보기", issues_path(project_id: @project.id), class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <div class="divide-y divide-gray-100">
    <% @issues.each do |issue| %>
      <div class="px-5 py-3 flex justify-between items-center hover:bg-gray-50">
        <div>
          <%= link_to issue.title, issue, class: "text-sm font-medium text-gray-900 hover:text-blue-600" %>
          <p class="text-xs text-gray-400"><%= issue.issue_no %> · <%= issue.assigned_to&.name %></p>
        </div>
        <div class="flex gap-2">
          <%= severity_badge(issue.severity) %>
          <%= status_badge(issue.status) %>
        </div>
      </div>
    <% end %>
  </div>
</div>
