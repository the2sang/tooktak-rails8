<%= form_with(model: project, class: "space-y-6") do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 space-y-4">
    <h3 class="text-lg font-semibold border-b pb-2">기본 정보</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :project_no, "공사번호", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :project_no, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :name, "공사명", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :project_type, "공사유형", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :project_type, Project.project_types.keys.map { |k| [Project.human_enum_name(k), k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :status, "상태", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, Project.statuses.keys.map { |k| [Project.human_enum_name(k), k] }, {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :contractor_id, "시공사", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :contractor_id, Company.where(company_type: [:general_contractor]).order(:name), :id, :name, { include_blank: "선택" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :client_company_id, "발주처", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :client_company_id, Company.where(company_type: :client).order(:name), :id, :name, { include_blank: "선택" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :manager_id, "현장소장", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :manager_id, User.where(role: [:admin, :manager]).order(:name), :id, :name, { include_blank: "선택" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :address, "주소", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :address, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
    </div>

    <h3 class="text-lg font-semibold border-b pb-2 pt-4">일정/예산</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= f.label :contract_date, "계약일", class: "block text-sm font-medium text-gray-700" %>
        <%= f.date_field :contract_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :start_date, "착공일", class: "block text-sm font-medium text-gray-700" %>
        <%= f.date_field :start_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :planned_end_date, "준공예정일", class: "block text-sm font-medium text-gray-700" %>
        <%= f.date_field :planned_end_date, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :contract_amount, "계약금액(원)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :contract_amount, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :budget_amount, "예산금액(원)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :budget_amount, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <div>
        <%= f.label :progress_rate, "공정률(%)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.number_field :progress_rate, step: 0.01, min: 0, max: 100, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= btn_secondary("취소", project.persisted? ? project_path(project) : projects_path) %>
    <%= f.submit project.persisted? ? "수정" : "등록", class: "inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 cursor-pointer" %>
  </div>
<% end %>
