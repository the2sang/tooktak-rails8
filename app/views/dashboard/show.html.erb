<% content_for(:title) { "대시보드 — tooktak" } %>

<div class="space-y-6">
  <!-- 요약 카드 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-blue-500">
      <p class="text-sm text-gray-500">진행중 프로젝트</p>
      <p class="text-2xl font-bold text-gray-900"><%= Project.where(status: :in_progress).count %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-yellow-500">
      <p class="text-sm text-gray-500">대기중 작업지시</p>
      <p class="text-2xl font-bold text-gray-900"><%= WorkOrder.where(status: [:pending, :in_progress]).count %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-red-500">
      <p class="text-sm text-gray-500">미해결 이슈</p>
      <p class="text-2xl font-bold text-gray-900"><%= Issue.where(status: [:open, :in_progress]).count %></p>
    </div>
    <div class="bg-white rounded-lg shadow p-5 border-l-4 border-green-500">
      <p class="text-sm text-gray-500">금월 기성청구</p>
      <p class="text-2xl font-bold text-gray-900"><%= Billing.where(payment_status: :pending).count %>건</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- 진행중 프로젝트 -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-900">진행중 프로젝트</h2>
        <%= link_to "전체보기", projects_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <div class="divide-y divide-gray-100">
        <% @projects.each do |project| %>
          <div class="px-5 py-3">
            <div class="flex justify-between items-start">
              <div>
                <%= link_to project.name, project_path(project), class: "font-medium text-gray-900 hover:text-blue-600" %>
                <p class="text-sm text-gray-500"><%= project.project_no %> · <%= project.contractor&.name %></p>
              </div>
              <div class="text-right">
                <span class="text-sm font-semibold text-blue-600"><%= project.progress_rate %>%</span>
                <div class="w-24 bg-gray-200 rounded-full h-2 mt-1">
                  <div class="bg-blue-600 h-2 rounded-full" style="width: <%= project.progress_rate %>%"></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 미해결 이슈 -->
    <div class="bg-white rounded-lg shadow">
      <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-semibold text-gray-900">미해결 이슈</h2>
        <%= link_to "전체보기", issues_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <div class="divide-y divide-gray-100">
        <% @recent_issues.each do |issue| %>
          <div class="px-5 py-3">
            <div class="flex justify-between items-start">
              <div>
                <%= link_to issue.title, issue_path(issue), class: "font-medium text-gray-900 hover:text-blue-600" %>
                <p class="text-sm text-gray-500">
                  <%= issue.issue_no %> · <%= issue.project&.name&.truncate(20) %>
                </p>
              </div>
              <div class="flex flex-col items-end gap-1">
                <% severity_colors = { "critical" => "bg-red-100 text-red-800", "major" => "bg-orange-100 text-orange-800", "minor" => "bg-yellow-100 text-yellow-800", "trivial" => "bg-gray-100 text-gray-800" } %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= severity_colors[issue.severity] %>">
                  <%= issue.severity_i18n %>
                </span>
                <span class="text-xs text-gray-400"><%= issue.assigned_to&.name %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 최근 작업지시 -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-gray-900">진행중 작업지시</h2>
      <%= link_to "전체보기", work_orders_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
    </div>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">지시번호</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">담당자</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">우선순위</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @recent_work_orders.each do |wo| %>
          <tr>
            <td class="px-5 py-3 text-sm text-gray-500"><%= wo.order_no %></td>
            <td class="px-5 py-3 text-sm">
              <%= link_to wo.title.truncate(30), work_order_path(wo), class: "text-gray-900 hover:text-blue-600" %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= wo.project&.name&.truncate(20) %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= wo.assigned_to&.name %></td>
            <td class="px-5 py-3 text-sm">
              <% priority_colors = { "low" => "bg-gray-100 text-gray-800", "medium" => "bg-blue-100 text-blue-800", "high" => "bg-orange-100 text-orange-800", "urgent" => "bg-red-100 text-red-800" } %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= priority_colors[wo.priority] %>">
                <%= wo.priority_i18n %>
              </span>
            </td>
            <td class="px-5 py-3 text-sm">
              <% status_colors = { "draft" => "bg-gray-100 text-gray-800", "pending" => "bg-yellow-100 text-yellow-800", "in_progress" => "bg-blue-100 text-blue-800", "completed" => "bg-green-100 text-green-800" } %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status_colors[wo.status] || 'bg-gray-100 text-gray-800' %>">
                <%= wo.status_i18n %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
