<% content_for(:title) { "대시보드 — tooktak" } %>

<div class="space-y-6">
  <!-- 요약 카드 -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 shrink-0">
        <i class="fa-solid fa-folder-open text-lg" aria-hidden="true"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-medium">진행중 프로젝트</p>
        <p class="text-2xl font-bold text-gray-900"><%= Project.where(status: :in_progress).count %></p>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 text-amber-600 shrink-0">
        <i class="fa-solid fa-clipboard-list text-lg" aria-hidden="true"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-medium">대기중 작업지시</p>
        <p class="text-2xl font-bold text-gray-900"><%= WorkOrder.where(status: [:pending, :in_progress]).count %></p>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-red-50 text-red-600 shrink-0">
        <i class="fa-solid fa-triangle-exclamation text-lg" aria-hidden="true"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-medium">미해결 이슈</p>
        <p class="text-2xl font-bold text-gray-900"><%= Issue.where(status: [:open, :in_progress]).count %></p>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 flex items-center gap-4">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-600 shrink-0">
        <i class="fa-solid fa-file-invoice text-lg" aria-hidden="true"></i>
      </div>
      <div>
        <p class="text-xs text-gray-500 font-medium">금월 기성청구</p>
        <p class="text-2xl font-bold text-gray-900"><%= Billing.where(payment_status: :pending).count %>건</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- 진행중 프로젝트 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-5 py-4 border-b border-gray-100 flex justify-between items-center">
        <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-folder-open text-blue-500" aria-hidden="true"></i>
          진행중 프로젝트
        </h2>
        <%= link_to "전체보기", projects_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
      </div>
      <div class="divide-y divide-gray-50">
        <% @projects.each do |project| %>
          <div class="px-5 py-3">
            <div class="flex justify-between items-start">
              <div>
                <%= link_to project.name, project_path(project), class: "text-sm font-medium text-gray-900 hover:text-blue-600" %>
                <p class="text-xs text-gray-400 mt-0.5"><%= project.project_no %> · <%= project.contractor&.name %></p>
              </div>
              <div class="text-right">
                <span class="text-sm font-semibold text-blue-600"><%= project.progress_rate %>%</span>
                <div class="w-24 bg-gray-100 rounded-full h-1.5 mt-1.5">
                  <div class="bg-blue-500 h-1.5 rounded-full" style="width: <%= project.progress_rate %>%"></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 미해결 이슈 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-5 py-4 border-b border-gray-100 flex justify-between items-center">
        <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
          <i class="fa-solid fa-triangle-exclamation text-red-500" aria-hidden="true"></i>
          미해결 이슈
        </h2>
        <%= link_to "전체보기", issues_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
      </div>
      <div class="divide-y divide-gray-50">
        <% @recent_issues.each do |issue| %>
          <div class="px-5 py-3">
            <div class="flex justify-between items-start">
              <div>
                <%= link_to issue.title, issue_path(issue), class: "text-sm font-medium text-gray-900 hover:text-blue-600" %>
                <p class="text-xs text-gray-400 mt-0.5">
                  <%= issue.issue_no %> · <%= issue.project&.name&.truncate(20) %>
                </p>
              </div>
              <div class="flex flex-col items-end gap-1">
                <%= severity_badge(issue.severity) %>
                <span class="text-xs text-gray-400"><%= issue.assigned_to&.name %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 진행중 작업지시 -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
        <i class="fa-solid fa-clipboard-list text-amber-500" aria-hidden="true"></i>
        진행중 작업지시
      </h2>
      <%= link_to "전체보기", work_orders_path, class: "text-xs text-blue-600 hover:text-blue-800 font-medium" %>
    </div>
    <table class="min-w-full divide-y divide-gray-100">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">지시번호</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">제목</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">프로젝트</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">담당자</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">우선순위</th>
          <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">상태</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-50">
        <% @recent_work_orders.each do |wo| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-3 text-sm text-gray-400 font-mono"><%= wo.order_no %></td>
            <td class="px-5 py-3 text-sm">
              <%= link_to wo.title.truncate(30), work_order_path(wo), class: "text-gray-900 hover:text-blue-600 font-medium" %>
            </td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= wo.project&.name&.truncate(20) %></td>
            <td class="px-5 py-3 text-sm text-gray-500"><%= wo.assigned_to&.name %></td>
            <td class="px-5 py-3 text-sm"><%= priority_badge(wo.priority) %></td>
            <td class="px-5 py-3 text-sm"><%= status_badge(wo.status) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
