<%= page_header("문서 관리") { btn_primary("+ 문서 등록", new_document_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">파일명</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">등록자</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">등록일</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @documents.each do |doc| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm"><%= link_to doc.title, doc, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= doc.project.name.truncate(20) %></td>
          <td class="px-5 py-3 text-sm"><%= badge(doc.doc_type_i18n, :indigo) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= doc.file_name %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= doc.uploaded_by&.name %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= doc.created_at.strftime("%Y-%m-%d") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
