<!DOCTYPE html>
<html class="h-full" style="background-color: #f9fafb; color-scheme: light;">
  <head>
    <title><%= content_for(:title) || "tooktak 시공관리" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="tooktak">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { font-family: 'Geist', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
    </style>
  </head>

  <body class="h-full bg-gray-50 text-gray-900 antialiased">
    <% if Current.session %>
      <div class="min-h-full" data-controller="sidebar">
        <!-- 사이드바 -->
        <%= render "shared/sidebar" %>

        <!-- 메인 콘텐츠 -->
        <div class="lg:pl-64">
          <!-- 상단 바 -->
          <%= render "shared/topbar" %>

          <!-- 콘텐츠 -->
          <main class="py-6 px-4 sm:px-6 lg:px-8">
            <% if notice.present? %>
              <div class="mb-4 rounded-lg bg-white border border-emerald-200 p-4" data-controller="dismissible">
                <div class="flex items-start gap-3">
                  <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5 shrink-0 text-sm"></i>
                  <p class="text-sm text-gray-700"><%= notice %></p>
                  <button data-action="click->dismissible#dismiss" class="ml-auto text-gray-400 hover:text-gray-600 transition-colors">
                    <i class="fa-solid fa-xmark text-sm"></i>
                  </button>
                </div>
              </div>
            <% end %>

            <% if alert.present? %>
              <div class="mb-4 rounded-lg bg-white border border-red-200 p-4">
                <div class="flex items-start gap-3">
                  <i class="fa-solid fa-circle-xmark text-red-500 mt-0.5 shrink-0 text-sm"></i>
                  <p class="text-sm text-gray-700"><%= alert %></p>
                </div>
              </div>
            <% end %>

            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <!-- 비로그인 상태 -->
      <div class="min-h-screen flex items-center justify-center py-12 px-4 bg-gray-50">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
