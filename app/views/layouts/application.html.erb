<!DOCTYPE html>
<html class="h-full" style="background-color: #09090b; color-scheme: dark;">
  <head>
    <title><%= content_for(:title) || "tooktak 시공관리" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="tooktak">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { font-family: 'Geist', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
    </style>
  </head>

  <body class="h-full bg-zinc-950 text-zinc-100 antialiased">
    <% if Current.session %>
      <div class="min-h-full" data-controller="sidebar">
        <!-- 사이드바 -->
        <%= render "shared/sidebar" %>

        <!-- 메인 콘텐츠 -->
        <div class="lg:pl-64">
          <!-- 상단 바 -->
          <%= render "shared/topbar" %>

          <!-- 콘텐츠 -->
          <main class="py-6 px-4 sm:px-6 lg:px-8">
            <% if notice.present? %>
              <div class="mb-4 rounded-lg bg-zinc-900 border border-emerald-800/40 p-4" data-controller="dismissible">
                <div class="flex items-start gap-3">
                  <svg class="h-4 w-4 text-emerald-400 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                  </svg>
                  <p class="text-sm text-zinc-300"><%= notice %></p>
                  <button data-action="click->dismissible#dismiss" class="ml-auto text-zinc-500 hover:text-zinc-300 transition-colors">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
                  </button>
                </div>
              </div>
            <% end %>

            <% if alert.present? %>
              <div class="mb-4 rounded-lg bg-zinc-900 border border-red-800/40 p-4">
                <div class="flex items-start gap-3">
                  <svg class="h-4 w-4 text-red-400 mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                  </svg>
                  <p class="text-sm text-zinc-300"><%= alert %></p>
                </div>
              </div>
            <% end %>

            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <!-- 비로그인 상태 -->
      <div class="min-h-screen flex items-center justify-center py-12 px-4 bg-zinc-950">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
