<%= page_header("이슈/하자") { btn_primary("+ 새 이슈", new_issue_path) } %>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">이슈번호</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">위치</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">담당자</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">심각도</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @issues.each do |issue| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-500"><%= issue.issue_no %></td>
          <td class="px-5 py-3 text-sm"><%= link_to issue.title.truncate(30), issue, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= link_to issue.project.name.truncate(20), issue.project, class: "hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= issue.location %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= issue.assigned_to&.name %></td>
          <td class="px-5 py-3 text-sm"><%= severity_badge(issue.severity) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(issue.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
