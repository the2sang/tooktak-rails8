<!-- 사이드바 (데스크톱) -->
<div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-64 lg:flex-col">
  <div class="flex grow flex-col overflow-y-auto bg-zinc-950 border-r border-zinc-800/60 px-4 pb-4">
    <!-- 로고 -->
    <div class="flex h-14 shrink-0 items-center px-2 border-b border-zinc-800/60">
      <a href="/" class="flex items-center gap-2 group">
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-zinc-100 text-zinc-900">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="text-sm font-semibold text-zinc-100 tracking-tight">tooktak</span>
        <span class="text-xs text-zinc-500">시공관리</span>
      </a>
    </div>

    <nav class="flex flex-1 flex-col pt-4">
      <ul role="list" class="flex flex-1 flex-col gap-y-6">
        <!-- 메인 메뉴 -->
        <li>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "대시보드", root_path, "home" %>
            <%= sidebar_link "프로젝트", projects_path, "folder" %>
            <%= sidebar_link "작업지시", work_orders_path, "clipboard" %>
            <%= sidebar_link "작업일보", daily_reports_path, "document" %>
            <%= sidebar_link "이슈/하자", issues_path, "exclamation" %>
          </ul>
        </li>

        <!-- 품질/안전 -->
        <li>
          <p class="px-2 text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">품질 · 안전</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "검사", inspections_path, "check" %>
            <%= sidebar_link "안전점검", safety_checks_path, "shield" %>
          </ul>
        </li>

        <!-- 자원관리 -->
        <li>
          <p class="px-2 text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">자원 관리</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "자재", materials_path, "cube" %>
            <%= sidebar_link "근로자", workers_path, "users" %>
          </ul>
        </li>

        <!-- 비용관리 -->
        <li>
          <p class="px-2 text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">비용 관리</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "비용", costs_path, "currency" %>
            <%= sidebar_link "기성청구", billings_path, "receipt" %>
          </ul>
        </li>

        <!-- 기타 -->
        <li>
          <p class="px-2 text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">기타</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "문서", documents_path, "paperclip" %>
            <%= sidebar_link "회사", companies_path, "building" %>
          </ul>
        </li>

        <!-- 사용자 -->
        <li class="mt-auto pt-4 border-t border-zinc-800/60">
          <div class="flex items-center gap-x-3 rounded-md px-2 py-2 text-sm">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-zinc-800 text-zinc-300 text-xs font-medium shrink-0">
              <%= Current.user&.name&.first %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-zinc-200 truncate"><%= Current.user&.name %></p>
              <p class="text-xs text-zinc-500 truncate"><%= Current.user&.role_i18n %></p>
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</div>

<!-- 모바일 오버레이 사이드바 -->
<div class="lg:hidden" data-sidebar-target="mobileMenu" style="display:none;">
  <div class="fixed inset-0 z-50 flex">
    <div class="fixed inset-0 bg-zinc-950/80 backdrop-blur-sm" data-action="click->sidebar#toggle"></div>
    <div class="relative flex w-64 flex-col bg-zinc-950 border-r border-zinc-800/60 px-4 pb-4">
      <div class="flex h-14 shrink-0 items-center px-2 border-b border-zinc-800/60">
        <span class="text-sm font-semibold text-zinc-100">tooktak</span>
        <span class="ml-2 text-xs text-zinc-500">시공관리</span>
        <button class="ml-auto text-zinc-500 hover:text-zinc-300" data-action="click->sidebar#toggle">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <nav class="mt-4">
        <ul role="list" class="space-y-0.5">
          <%= sidebar_link "대시보드", root_path, "home" %>
          <%= sidebar_link "프로젝트", projects_path, "folder" %>
          <%= sidebar_link "작업지시", work_orders_path, "clipboard" %>
          <%= sidebar_link "작업일보", daily_reports_path, "document" %>
          <%= sidebar_link "이슈/하자", issues_path, "exclamation" %>
          <%= sidebar_link "검사", inspections_path, "check" %>
          <%= sidebar_link "안전점검", safety_checks_path, "shield" %>
          <%= sidebar_link "자재", materials_path, "cube" %>
          <%= sidebar_link "근로자", workers_path, "users" %>
          <%= sidebar_link "비용", costs_path, "currency" %>
          <%= sidebar_link "기성청구", billings_path, "receipt" %>
          <%= sidebar_link "문서", documents_path, "paperclip" %>
          <%= sidebar_link "회사", companies_path, "building" %>
        </ul>
      </nav>
    </div>
  </div>
</div>
