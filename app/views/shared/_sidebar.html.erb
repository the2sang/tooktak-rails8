<!-- 사이드바 (데스크톱) -->
<div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-64 lg:flex-col">
  <div class="flex grow flex-col overflow-y-auto bg-white border-r border-gray-200 px-4 pb-4">
    <!-- 로고 -->
    <div class="flex h-14 shrink-0 items-center px-2 border-b border-gray-200">
      <a href="/" class="flex items-center gap-2 group">
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-blue-600 text-white">
          <i class="fa-solid fa-helmet-safety text-xs" aria-hidden="true"></i>
        </div>
        <span class="text-sm font-semibold text-gray-900 tracking-tight">tooktak</span>
        <span class="text-xs text-gray-400">시공관리</span>
      </a>
    </div>

    <nav class="flex flex-1 flex-col pt-4">
      <ul role="list" class="flex flex-1 flex-col gap-y-6">
        <!-- 메인 메뉴 -->
        <li>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "대시보드", root_path, "home" %>
            <%= sidebar_link "프로젝트", projects_path, "folder" %>
            <%= sidebar_link "작업지시", work_orders_path, "clipboard" %>
            <%= sidebar_link "작업일보", daily_reports_path, "document" %>
            <%= sidebar_link "이슈/하자", issues_path, "exclamation" %>
          </ul>
        </li>

        <!-- 품질/안전 -->
        <li>
          <p class="px-2 text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">품질 · 안전</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "검사", inspections_path, "check" %>
            <%= sidebar_link "안전점검", safety_checks_path, "shield" %>
          </ul>
        </li>

        <!-- 자원관리 -->
        <li>
          <p class="px-2 text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">자원 관리</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "자재", materials_path, "cube" %>
            <%= sidebar_link "근로자", workers_path, "users" %>
          </ul>
        </li>

        <!-- 비용관리 -->
        <li>
          <p class="px-2 text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">비용 관리</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "비용", costs_path, "currency" %>
            <%= sidebar_link "기성청구", billings_path, "receipt" %>
          </ul>
        </li>

        <!-- 기타 -->
        <li>
          <p class="px-2 text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">기타</p>
          <ul role="list" class="space-y-0.5">
            <%= sidebar_link "문서", documents_path, "paperclip" %>
            <%= sidebar_link "회사", companies_path, "building" %>
          </ul>
        </li>

        <!-- 사용자 -->
        <li class="mt-auto pt-4 border-t border-gray-200">
          <div class="flex items-center gap-x-3 rounded-md px-2 py-2 text-sm">
            <div class="flex h-7 w-7 items-center justify-center rounded-full bg-gray-200 text-gray-700 text-xs font-medium shrink-0">
              <%= Current.user&.name&.first %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= Current.user&.name %></p>
              <p class="text-xs text-gray-500 truncate"><%= Current.user&.role_i18n %></p>
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>
</div>

<!-- 모바일 오버레이 사이드바 -->
<div class="lg:hidden" data-sidebar-target="mobileMenu" style="display:none;">
  <div class="fixed inset-0 z-50 flex">
    <div class="fixed inset-0 bg-gray-900/80 backdrop-blur-sm" data-action="click->sidebar#toggle"></div>
    <div class="relative flex w-64 flex-col bg-white border-r border-gray-200 px-4 pb-4">
      <div class="flex h-14 shrink-0 items-center px-2 border-b border-gray-200">
        <i class="fa-solid fa-helmet-safety text-blue-600 text-sm mr-2" aria-hidden="true"></i>
        <span class="text-sm font-semibold text-gray-900">tooktak</span>
        <span class="ml-2 text-xs text-gray-400">시공관리</span>
        <button class="ml-auto text-gray-400 hover:text-gray-600" data-action="click->sidebar#toggle">
          <i class="fa-solid fa-xmark text-lg" aria-hidden="true"></i>
        </button>
      </div>
      <nav class="mt-4">
        <ul role="list" class="space-y-0.5">
          <%= sidebar_link "대시보드", root_path, "home" %>
          <%= sidebar_link "프로젝트", projects_path, "folder" %>
          <%= sidebar_link "작업지시", work_orders_path, "clipboard" %>
          <%= sidebar_link "작업일보", daily_reports_path, "document" %>
          <%= sidebar_link "이슈/하자", issues_path, "exclamation" %>
          <%= sidebar_link "검사", inspections_path, "check" %>
          <%= sidebar_link "안전점검", safety_checks_path, "shield" %>
          <%= sidebar_link "자재", materials_path, "cube" %>
          <%= sidebar_link "근로자", workers_path, "users" %>
          <%= sidebar_link "비용", costs_path, "currency" %>
          <%= sidebar_link "기성청구", billings_path, "receipt" %>
          <%= sidebar_link "문서", documents_path, "paperclip" %>
          <%= sidebar_link "회사", companies_path, "building" %>
        </ul>
      </nav>
    </div>
  </div>
</div>
