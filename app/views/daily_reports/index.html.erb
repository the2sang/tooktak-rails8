<%= page_header("작업일보") { btn_primary("+ 새 일보", new_daily_report_path) } %>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">날짜</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">날씨</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">투입인원</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">작성자</th>
        <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">작업개요</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @daily_reports.each do |dr| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm font-medium"><%= link_to format_date(dr.report_date), dr, class: "text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= dr.project.name.truncate(25) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= dr.weather %> <%= dr.temperature %>℃</td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= dr.worker_count %>명</td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= dr.created_by.name %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= dr.work_summary&.truncate(40) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
