<%= page_header("자재 관리") { btn_primary("+ 새 자재", new_material_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">코드</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">자재명</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">분류</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">규격</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">단위</th>
      <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">단가</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">공급업체</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @materials.each do |mat| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-500"><%= mat.code %></td>
          <td class="px-5 py-3 text-sm"><%= link_to mat.name, mat, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= mat.category %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= mat.specification %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= mat.unit %></td>
          <td class="px-5 py-3 text-sm text-right text-gray-700"><%= format_amount(mat.unit_price) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= mat.supplier&.name %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
