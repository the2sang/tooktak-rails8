<%= page_header("비용 상세") { btn_secondary("편집", edit_cost_path(@cost)) } %>
<div class="bg-white shadow rounded-lg p-6">
  <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
    <div><dt class="text-gray-500">프로젝트</dt><dd><%= link_to @cost.project.name, @cost.project, class: "text-blue-600" %></dd></div>
    <div><dt class="text-gray-500">분류</dt><dd><%= badge(@cost.category_i18n, :blue) %></dd></div>
    <div><dt class="text-gray-500">날짜</dt><dd><%= format_date(@cost.cost_date) %></dd></div>
    <div><dt class="text-gray-500">금액</dt><dd class="font-semibold"><%= format_amount(@cost.amount) %></dd></div>
    <div><dt class="text-gray-500">결제상태</dt><dd><%= status_badge(@cost.payment_status) %></dd></div>
    <div><dt class="text-gray-500">기록자</dt><dd><%= @cost.recorded_by&.name %></dd></div>
    <div class="col-span-2"><dt class="text-gray-500">내역</dt><dd><%= @cost.description %></dd></div>
  </dl>
</div>
