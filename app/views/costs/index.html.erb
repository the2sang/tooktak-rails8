<%= page_header("비용 관리") { btn_primary("+ 비용 등록", new_cost_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">날짜</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">분류</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">내역</th>
      <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">금액</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">결제</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @costs.each do |cost| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm text-gray-500"><%= format_date(cost.cost_date) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= cost.project.name.truncate(20) %></td>
          <td class="px-5 py-3 text-sm"><%= badge(cost.category_i18n, :blue) %></td>
          <td class="px-5 py-3 text-sm"><%= link_to cost.description.truncate(30), cost, class: "text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-right font-medium"><%= format_amount(cost.amount) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(cost.payment_status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
