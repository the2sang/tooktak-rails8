<%= page_header("검사") { btn_primary("+ 새 검사", new_inspection_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">제목</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">유형</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">검사자</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">예정일</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @inspections.each do |insp| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm"><%= link_to insp.title, insp, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= insp.project.name.truncate(20) %></td>
          <td class="px-5 py-3 text-sm"><%= badge(insp.inspection_type_i18n, :indigo) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= insp.inspector&.name %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= format_date(insp.scheduled_date) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(insp.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
