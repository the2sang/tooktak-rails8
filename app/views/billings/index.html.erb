<%= page_header("기성청구") { btn_primary("+ 새 청구", new_billing_path) } %>
<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50"><tr>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">청구번호</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">프로젝트</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">청구월</th>
      <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">기성율</th>
      <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">청구금액</th>
      <th class="px-5 py-3 text-right text-xs font-medium text-gray-500 uppercase">승인금액</th>
      <th class="px-5 py-3 text-left text-xs font-medium text-gray-500 uppercase">상태</th>
    </tr></thead>
    <tbody class="divide-y divide-gray-200">
      <% @billings.each do |b| %>
        <tr class="hover:bg-gray-50">
          <td class="px-5 py-3 text-sm"><%= link_to b.billing_no, b, class: "font-medium text-gray-900 hover:text-blue-600" %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= b.project.name.truncate(20) %></td>
          <td class="px-5 py-3 text-sm text-gray-500"><%= b.billing_month.strftime("%Y년 %m월") %></td>
          <td class="px-5 py-3 text-sm text-right"><%= b.progress_rate %>%</td>
          <td class="px-5 py-3 text-sm text-right font-medium"><%= format_amount(b.claim_amount) %></td>
          <td class="px-5 py-3 text-sm text-right"><%= format_amount(b.approved_amount) %></td>
          <td class="px-5 py-3 text-sm"><%= status_badge(b.payment_status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
